# Copy to .env.local for local development.
# Configure the SAME keys in Vercel → Project → Settings → Environment Variables
# (Production + Preview). Redeploy after adding vars.

# Telegram Bot API (required for Telegram delivery)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Namecheap Private Email SMTP (required for email delivery)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@rolanautomation.com
SMTP_PASS=
SMTP_FROM=contact@rolanautomation.com

# Business inbox that receives consultation leads
# CONTACT_EMAIL is preferred; CONSULTATION_EMAIL_TO is also supported
CONTACT_EMAIL=contact@rolanautomation.com
CONSULTATION_EMAIL_TO=contact@rolanautomation.com

# Optional: absolute logo URL for HTML emails (PNG recommended for inbox compatibility)
EMAIL_LOGO_URL=https://rolanautomation.com/logo.png
